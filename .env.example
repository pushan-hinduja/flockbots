# =============================================================================
# Tasklings configuration
# =============================================================================
# Generated by `tasklings init`. Re-run the wizard (or `tasklings config edit`)
# instead of editing by hand. Every variable has a wizard prompt or sensible
# default.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic authentication (pick ONE)
# -----------------------------------------------------------------------------
# If using Claude Max plan:   leave ANTHROPIC_API_KEY blank; run `claude login`.
# If using an API key:        set ANTHROPIC_API_KEY and leave Max unauthed.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# GitHub Apps (REQUIRED) — two apps, separate identities for PRs and reviews
# -----------------------------------------------------------------------------
# PR creator app
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=

# Reviewer app
REVIEWER_GITHUB_APP_ID=
REVIEWER_GITHUB_APP_PRIVATE_KEY_PATH=
REVIEWER_GITHUB_APP_INSTALLATION_ID=

# Target repository (REQUIRED)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_STAGING_BRANCH=staging
GITHUB_PROD_BRANCH=main

# -----------------------------------------------------------------------------
# Chat provider (REQUIRED — pick ONE: "telegram", "slack", or "whatsapp")
# -----------------------------------------------------------------------------
CHAT_PROVIDER=telegram

# Telegram (if CHAT_PROVIDER=telegram) — simple, long-polling, no public URL
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack (if CHAT_PROVIDER=slack) — Socket Mode, no public URL required
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# WhatsApp Cloud API via Meta Business (if CHAT_PROVIDER=whatsapp)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# App secret used to HMAC-verify incoming webhooks. Found in the Meta
# developer dashboard: App → Basic → App secret. REQUIRED for inbound.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=change-me-to-any-long-random-string
OPERATOR_WHATSAPP_NUMBER=
WHATSAPP_WEBHOOK_PORT=3001

# -----------------------------------------------------------------------------
# Linear (OPTIONAL — task sync). Leave blank to disable.
# -----------------------------------------------------------------------------
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_AGENT_READY_LABEL=agent-ready

# -----------------------------------------------------------------------------
# Supabase + dashboard (OPTIONAL — web UI). Leave blank to disable.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# QA agent (OPTIONAL — post-merge Playwright browser tests)
# -----------------------------------------------------------------------------
QA_ENABLED=false
STAGING_BASE_URL=
QA_TEST_EMAIL=
QA_TEST_PASSWORD=
SUPABASE_STORAGE_BUCKET_QA=qa-media
QA_HEADLESS=true
# Wait time after merge before QA runs (ms). Gives the deploy target time to ship.
QA_DEPLOY_WAIT_MS=300000

# -----------------------------------------------------------------------------
# Test commands (auto-detected by wizard; override if needed)
# -----------------------------------------------------------------------------
INSTALL_COMMAND=npm install
TEST_COMMAND=npm test
LINT_COMMAND=npm run lint
TYPECHECK_COMMAND=npx tsc --noEmit

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Absolute path to the target codebase Tasklings works on (REQUIRED)
TARGET_REPO_PATH=

# Where Tasklings stores its own state (db, tasks, logs, keys).
# Defaults to ~/.tasklings if unset.
# TASKLINGS_HOME=
